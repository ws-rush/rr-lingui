{
  "name": "lingui-rr",
  "version": "0.1.0",
  "description": "React Router v8 framework-mode integration for Lingui.",
  "type": "module",
  "license": "MIT",
  "author": "ws-rush",
  "homepage": "https://github.com/ws-rush/lingui-rr#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ws-rush/lingui-rr.git"
  },
  "bugs": {
    "url": "https://github.com/ws-rush/lingui-rr/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "vitest run --dir tests",
    "test:e2e": "pnpm build && pnpm pack && rm -rf e2e/node_modules/lingui-rr && mkdir -p e2e/node_modules/lingui-rr && tar -xzf lingui-rr-*.tgz -C e2e/node_modules/lingui-rr --strip-components=1 && rm -f lingui-rr-*.tgz && pnpm --filter @lingui-rr/e2e test",
    "test:all": "pnpm test && pnpm test:e2e",
    "fallow": "fallow audit",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --ignore-path .gitignore --deny-warnings --type-aware --tsconfig tsconfig.lint.json",
    "lint:fix": "oxlint . --ignore-path .gitignore --fix --type-aware --tsconfig tsconfig.lint.json",
    "format:check": "oxfmt . --check --ignore-path .gitignore",
    "format": "oxfmt . --write --ignore-path .gitignore",
    "build": "rm -rf dist && vite build",
    "release": "bumpp",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "react-router",
    "lingui",
    "i18n",
    "internationalization",
    "localization",
    "react"
  ],
  "peerDependencies": {
    "@lingui/core": "^6.0.0",
    "@lingui/react": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^8.0.0"
  },
  "devDependencies": {
    "@lingui/core": "^6.4.0",
    "@lingui/react": "^6.4.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bumpp": "^11.1.0",
    "fallow": "^2.102.0",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "^8.0.1",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "vite-plugin-dts": "^5.0.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.18",
    "vue": "^3.5.39"
  },
  "engines": {
    "node": ">=22.22"
  },
  "packageManager": "pnpm@10.10.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
